#!/bin/bash
# styx — Graceful cluster shutdown for Proxmox + Kubernetes + Ceph
set -euo pipefail

STYX_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${STYX_DIR}/lib/config.sh"
source "${STYX_DIR}/lib/discover.sh"
source "${STYX_DIR}/lib/classify.sh"
source "${STYX_DIR}/lib/decide.sh"
source "${STYX_DIR}/lib/wrappers.sh"

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
PHASE=3
DRY_RUN=false
CONFIG_FILE="/etc/styx/styx.conf"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_FILE="${LOG_FILE:-/var/log/styx.log}"

_log_setup() {
  mkdir -p "$(dirname "$LOG_FILE")"
  exec > >(while IFS= read -r line; do
    printf '[%s] %s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$line"
  done | tee -a "$LOG_FILE") 2>&1
}

log() { echo "$*"; }

log_separator() {
  echo "========================================"
  echo "styx run started at $(date '+%Y-%m-%dT%H:%M:%S')"
  echo "========================================"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)        DRY_RUN=true ;;
      --phase)          PHASE="$2"; shift ;;
      --config)         CONFIG_FILE="$2"; shift ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
    shift
  done

  if [[ "$PHASE" != "1" && "$PHASE" != "2" && "$PHASE" != "3" ]]; then
    echo "ERROR: --phase must be 1, 2, or 3" >&2
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Dry-run wrapper
# ---------------------------------------------------------------------------
maybe() {
  if [[ "$DRY_RUN" == "true" ]]; then
    log "[dry-run] $*"
  else
    "$@"
  fi
}

# ---------------------------------------------------------------------------
# Discovery
# ---------------------------------------------------------------------------
run_discovery() {
  log "--- Discovery ---"

  # Load config (sets STYX_* override variables)
  parse_config "$CONFIG_FILE"

  # Hosts
  if [[ ${#STYX_HOSTS[@]} -gt 0 ]]; then
    log "Hosts: using config override"
    declare -gA HOST_IPS=()
    local h
    for h in "${!STYX_HOSTS[@]}"; do
      HOST_IPS["$h"]="${STYX_HOSTS[$h]}"
    done
    # Orchestrator from config or default to local hostname
    ORCHESTRATOR="${STYX_ORCHESTRATOR:-$(hostname -s)}"
  else
    local cluster_json
    cluster_json="$(pvesh get /cluster/status --output-format json)"
    parse_cluster_status "$cluster_json"
    [[ -n "${STYX_ORCHESTRATOR:-}" ]] && ORCHESTRATOR="$STYX_ORCHESTRATOR"
  fi
  log "Orchestrator: ${ORCHESTRATOR}"
  local _h; local _hosts_str=""
  for _h in "${!HOST_IPS[@]}"; do _hosts_str+="${_h}(${HOST_IPS[$_h]}) "; done
  log "Hosts: ${_hosts_str}"

  # VMs
  local resources_json
  resources_json="$(pvesh get /cluster/resources --type vm --output-format json)"
  parse_cluster_resources "$resources_json"
  log "Running VMs: ${!VMID_HOST[*]}"

  # Kubernetes
  _discover_k8s

  # Ceph
  if [[ -n "${STYX_CEPH_ENABLED:-}" ]]; then
    CEPH_ENABLED="$STYX_CEPH_ENABLED"
  elif pveceph status >/dev/null 2>&1; then
    CEPH_ENABLED="true"
  else
    CEPH_ENABLED="false"
  fi
  log "Ceph enabled: ${CEPH_ENABLED}"

  # Timeouts (defaults already set by parse_config)
  TIMEOUT_DRAIN="${STYX_TIMEOUT_DRAIN:-120}"
  TIMEOUT_VM="${STYX_TIMEOUT_VM:-120}"
  log "Timeouts: drain=${TIMEOUT_DRAIN}s vm=${TIMEOUT_VM}s"
}

_discover_k8s() {
  # If workers/CP explicitly configured, use them directly
  if [[ -n "${STYX_WORKERS:-}" || -n "${STYX_CP:-}" ]]; then
    mapfile -t K8S_WORKERS <<< "$(echo "${STYX_WORKERS:-}" | tr ' ' '\n' | grep -v '^$')"
    mapfile -t K8S_CP      <<< "$(echo "${STYX_CP:-}"      | tr ' ' '\n' | grep -v '^$')"
    log "Kubernetes: using config override (workers=${K8S_WORKERS[*]:-none} cp=${K8S_CP[*]:-none})"
    K8S_ENABLED=true
    return 0
  fi

  # Try kubectl auto-discovery
  if is_api_reachable; then
    local kubeconfig_arg=""
    [[ -n "${STYX_KUBECONFIG:-}" ]] && kubeconfig_arg="--kubeconfig=${STYX_KUBECONFIG}"
    local nodes_json
    nodes_json="$(kubectl ${kubeconfig_arg} get nodes -o json)"
    local node_roles
    node_roles="$(parse_kubectl_nodes "$nodes_json")"
    if ! match_nodes_to_vms VMID_NAME "$node_roles"; then
      exit 1
    fi
    log "Kubernetes workers: ${K8S_WORKERS[*]:-none}"
    log "Kubernetes control-plane: ${K8S_CP[*]:-none}"
    K8S_ENABLED=true
  else
    log "Kubernetes API unreachable and no [kubernetes] config — skipping k8s"
    K8S_WORKERS=()
    K8S_CP=()
    K8S_ENABLED=false
  fi
}

# ---------------------------------------------------------------------------
# HA disable
# ---------------------------------------------------------------------------
disable_ha_resources() {
  local scope="$1"   # "all" or "k8s"
  local -a target_vmids=()

  if [[ "$scope" == "k8s" ]]; then
    target_vmids=(
      "${K8S_WORKERS[@]+"${K8S_WORKERS[@]}"}"
      "${K8S_CP[@]+"${K8S_CP[@]}"}"
    )
  fi

  log "Disabling HA resources (scope: ${scope})"
  local sid
  while IFS= read -r sid; do
    [[ -z "$sid" ]] && continue
    if [[ "$scope" == "all" ]]; then
      log "Disabling HA: ${sid}"
      maybe disable_ha_sid "$sid" || log "WARNING: failed to disable HA for ${sid}, continuing"
    else
      # scope == k8s: only act if the sid's vmid is in target list
      local vmid="${sid#vm:}"
      local id
      local match=0
      for id in "${target_vmids[@]+"${target_vmids[@]}"}"; do
        [[ "$id" == "$vmid" ]] && match=1 && break
      done
      if [[ $match -eq 1 ]]; then
        log "Disabling HA: ${sid}"
        maybe disable_ha_sid "$sid" || log "WARNING: failed to disable HA for ${sid}, continuing"
      fi
    fi
  done < <(get_ha_started_sids)
}

# ---------------------------------------------------------------------------
# Kubernetes track (Track A)
# ---------------------------------------------------------------------------
run_k8s_track() {
  [[ "$K8S_ENABLED" != "true" ]] && return 0
  [[ ${#K8S_WORKERS[@]} -eq 0 && ${#K8S_CP[@]} -eq 0 ]] && return 0

  log "--- Track A: Kubernetes ---"

  # Drain workers in parallel, then issue VM shutdown
  local vmid node host
  declare -A drain_pids=()

  for vmid in "${K8S_WORKERS[@]+"${K8S_WORKERS[@]}"}"; do
    node="${VMID_NAME[$vmid]:-$vmid}"
    host="${VMID_HOST[$vmid]}"
    log "Draining worker node: ${node} (VM ${vmid} on ${host})"
    (
      maybe drain_node "$node" "$TIMEOUT_DRAIN" \
        && log "Drained worker node: ${node}" \
        || log "WARNING: drain timed out or failed for ${node}, proceeding to VM shutdown"
      log "Shutting down worker VM: ${vmid} on ${host}"
      maybe shutdown_vm "$host" "$vmid" "$TIMEOUT_VM" &
    ) &
    drain_pids["$vmid"]=$!
  done

  # Wait for all worker drains+shutdown-launches before starting CP drain
  for vmid in "${!drain_pids[@]}"; do
    wait "${drain_pids[$vmid]}" || true
  done
  log "All worker nodes drained"

  # Drain CP nodes in parallel, then issue VM shutdown
  drain_pids=()
  for vmid in "${K8S_CP[@]+"${K8S_CP[@]}"}"; do
    node="${VMID_NAME[$vmid]:-$vmid}"
    host="${VMID_HOST[$vmid]}"
    log "Draining control-plane node: ${node} (VM ${vmid} on ${host})"
    (
      maybe drain_node "$node" "$TIMEOUT_DRAIN" \
        && log "Drained control-plane node: ${node}" \
        || log "WARNING: drain timed out or failed for ${node}, proceeding to VM shutdown"
      log "Shutting down control-plane VM: ${vmid} on ${host}"
      maybe shutdown_vm "$host" "$vmid" "$TIMEOUT_VM" &
    ) &
    drain_pids["$vmid"]=$!
  done

  for vmid in "${!drain_pids[@]}"; do
    wait "${drain_pids[$vmid]}" || true
  done
  log "All control-plane nodes drained"
}

# ---------------------------------------------------------------------------
# Non-k8s VM track (Track B)
# ---------------------------------------------------------------------------
run_other_vm_track() {
  log "--- Track B: Non-k8s VMs ---"
  local vmid host
  for vmid in "${!VMID_HOST[@]}"; do
    [[ "$(classify_vmid "$vmid")" != "other" ]] && continue
    host="${VMID_HOST[$vmid]}"
    log "Shutting down VM: ${vmid} on ${host}"
    maybe shutdown_vm "$host" "$vmid" "$TIMEOUT_VM" &
  done
}

# ---------------------------------------------------------------------------
# Polling loop
# ---------------------------------------------------------------------------
run_polling_loop() {
  local do_poweroff="$1"   # "yes" / "no"
  log "--- Polling loop (poweroff=${do_poweroff}) ---"

  # In dry-run mode no VMs were actually stopped, so don't enter the real loop.
  if [[ "$DRY_RUN" == "true" ]]; then
    local host
    for host in "${!HOST_IPS[@]}"; do
      [[ "$host" == "$ORCHESTRATOR" ]] && continue
      log "[dry-run] would poweroff_host ${host}"
    done
    return 0
  fi

  declare -A powered_off=()
  # Orchestrator is never powered off via the loop (handled after loop)
  powered_off["$ORCHESTRATOR"]=1

  local all_done
  while true; do
    all_done=true

    local host
    for host in "${!HOST_IPS[@]}"; do
      # Check all hosts, including orchestrator (for VM status tracking)
      local running_vmids
      if [[ -v powered_off["$host"] && "$host" != "$ORCHESTRATOR" ]]; then
        continue
      fi

      # Collect running VMIDs on this host
      mapfile -t running_vmids < <(get_running_vmids "$host" 2>/dev/null || true)

      # Collect VMIDs assigned to this host
      local host_has_running=false
      local vmid
      for vmid in "${!VMID_HOST[@]}"; do
        [[ "${VMID_HOST[$vmid]}" != "$host" ]] && continue
        local r
        for r in "${running_vmids[@]+"${running_vmids[@]}"}"; do
          [[ "$r" == "$vmid" ]] && host_has_running=true && break
        done
        $host_has_running && break
      done

      if $host_has_running; then
        all_done=false
        log "Host ${host}: VMs still running (${running_vmids[*]+"${running_vmids[*]}"})"
      else
        if [[ "$host" != "$ORCHESTRATOR" && ! -v powered_off["$host"] ]]; then
          if [[ "$do_poweroff" == "yes" ]]; then
            log "Host ${host}: all VMs stopped — powering off"
            maybe poweroff_host "$host" || log "WARNING: poweroff failed or host already down: ${host}"
          fi
          powered_off["$host"]=1
        fi
      fi
    done

    # Check if all non-orchestrator hosts are done
    local h
    local peers_done=true
    for h in "${!HOST_IPS[@]}"; do
      [[ "$h" == "$ORCHESTRATOR" ]] && continue
      [[ -v powered_off["$h"] ]] || peers_done=false
    done

    if $all_done || $peers_done; then
      # Also verify orchestrator VMs are stopped before we proceed
      local orch_running
      mapfile -t orch_running < <(get_running_vmids "$ORCHESTRATOR" 2>/dev/null || true)
      local orch_has_running=false
      local vmid
      for vmid in "${!VMID_HOST[@]}"; do
        [[ "${VMID_HOST[$vmid]}" != "$ORCHESTRATOR" ]] && continue
        local r
        for r in "${orch_running[@]+"${orch_running[@]}"}"; do
          [[ "$r" == "$vmid" ]] && orch_has_running=true && break
        done
        $orch_has_running && break
      done

      if ! $orch_has_running; then
        log "All VMs stopped (including orchestrator)"
        break
      else
        log "Waiting for orchestrator VMs to stop: ${orch_running[*]+"${orch_running[*]}"}"
        all_done=false
      fi
    fi

    sleep "${STYX_POLL_INTERVAL:-10}"
  done
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  parse_args "$@"
  _log_setup
  log_separator
  log "Phase: ${PHASE}, dry-run: ${DRY_RUN}"

  run_discovery

  # Cordon all k8s nodes (always, idempotent)
  if [[ "$K8S_ENABLED" == "true" ]]; then
    log "--- Cordoning all k8s nodes ---"
    local vmid node
    for vmid in \
        "${K8S_WORKERS[@]+"${K8S_WORKERS[@]}"}" \
        "${K8S_CP[@]+"${K8S_CP[@]}"}"; do
      node="${VMID_NAME[$vmid]:-$vmid}"
      log "Cordoning: ${node}"
      maybe cordon_node "$node" || log "WARNING: cordon failed for ${node} (may already be cordoned)"
    done
  fi

  # Disable HA
  if [[ "$(should_disable_ha "$PHASE")" == "yes" ]]; then
    disable_ha_resources "all"
  elif [[ "$K8S_ENABLED" == "true" ]]; then
    disable_ha_resources "k8s"
  fi

  # Launch Track A and Track B concurrently
  run_k8s_track &
  local track_a_pid=$!

  if [[ "$PHASE" -ge 2 ]]; then
    run_other_vm_track
  fi

  # For phase 1, wait for Track A (drain+fire-and-forget shutdowns)
  # For phase 2+, wait for both tracks then enter polling loop
  wait "$track_a_pid" || true

  if [[ "$(should_run_polling "$PHASE")" == "no" ]]; then
    log "Phase ${PHASE} complete"
    exit 0
  fi

  # Set Ceph flags before any host goes down (phase 3 only)
  if [[ "$(should_set_ceph_flags "$PHASE")" == "yes" && "$CEPH_ENABLED" == "true" ]]; then
    log "--- Setting Ceph OSD flags ---"
    # shellcheck disable=SC2086
    maybe set_ceph_flags ${STYX_CEPH_FLAGS:-noout norecover norebalance nobackfill nodown noup}
  fi

  local do_poweroff
  do_poweroff="$(should_poweroff_hosts "$PHASE")"

  run_polling_loop "$do_poweroff"

  if [[ "$do_poweroff" == "yes" ]]; then
    log "Powering off orchestrator (self)"
    maybe poweroff_self
  else
    log "Phase ${PHASE} complete"
  fi
}

# Allow tests (or users) to override any function by sourcing a replacement
# wrappers file. Sourced last so it wins over all function definitions above.
[[ -n "${STYX_WRAPPERS_FILE:-}" ]] && source "${STYX_WRAPPERS_FILE}"

main "$@"
